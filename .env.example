# ============================================================
# TechStock Backend — Environment Configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# --- Runtime ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techstock?schema=public

# --- JWT ---
# Generate strong secrets, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=techstock
JWT_AUDIENCE=techstock-clients

# --- Security / bcrypt ---
BCRYPT_SALT_ROUNDS=12

# --- CORS ---
# Comma-separated list of allowed origins. Use * only in development.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# --- Logging ---
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
LOG_PRETTY=true

# --- File uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# --- Backups ---
BACKUP_DIR=backups

# --- Business defaults ---
DEFAULT_CURRENCY=KES
DEFAULT_TAX_RATE=16
LOW_STOCK_ALERTS=true
