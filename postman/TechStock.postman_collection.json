        {
          "name": "Get receipt",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/sales/{{saleId}}/receipt", "host": ["{{baseUrl}}"], "path": ["sales", "{{saleId}}", "receipt"] }
          }
        },
        {
          "name": "Return sale",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    { \"saleItemId\": \"{{saleItemId}}\", \"quantity\": 1 }\n  ],\n  \"restock\": true,\n  \"reason\": \"Customer changed mind\"\n}" },
            "url": { "raw": "{{baseUrl}}/sales/{{saleId}}/return", "host": ["{{baseUrl}}"], "path": ["sales", "{{saleId}}", "return"] }
