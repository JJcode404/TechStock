{
  "info": {
    "name": "TechStock POS API (v1)",
    "_postman_id": "b6f0a3d2-1c4e-4a2b-9f7a-techstockv1000",
    "description": "Offline-first Point of Sale backend. Requests are chainable: run **Auth → Login** first (it saves the access & refresh tokens), then the create requests save their resource IDs into collection variables for the read/update/delete requests to reuse.\n\nSet `baseUrl` (default http://localhost:4000/api/v1) in the environment or collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Attach the offline device id on every request (used for sync attribution).",
          "if (pm.collectionVariables.get('deviceId')) {",
          "  pm.request.headers.upsert({ key: 'X-Device-Id', value: pm.collectionVariables.get('deviceId') });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global sanity: every response should carry the success envelope.",
          "try {",
          "  const json = pm.response.json();",
          "  pm.test('has success flag', () => pm.expect(json).to.have.property('success'));",
          "} catch (e) { /* non-JSON (e.g. 204) */ }"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1" },
    { "key": "deviceId", "value": "postman-device-01" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "productBarcode", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "saleId", "value": "" },
    { "key": "saleItemId", "value": "" },
    { "key": "purchaseOrderId", "value": "" },
    { "key": "purchaseItemId", "value": "" },
    { "key": "expenseId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@techstock.local\",\n  \"username\": \"manager1\",\n  \"password\": \"Manager@123\",\n  \"firstName\": \"Mary\",\n  \"lastName\": \"Manager\",\n  \"phone\": \"0700000001\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Create a user. In production restrict this to admins. Defaults to CASHIER when `role` is omitted."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('accessToken', d.tokens.accessToken);",
                  "pm.collectionVariables.set('refreshToken', d.tokens.refreshToken);",
                  "console.log('Saved tokens for', d.user.username);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Log in with email or username. Saves `accessToken` and `refreshToken` to collection variables."
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const t = pm.response.json().data.tokens;",
                  "pm.collectionVariables.set('accessToken', t.accessToken);",
                  "pm.collectionVariables.set('refreshToken', t.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "description": "Rotates tokens. The presented refresh token is revoked; reusing it triggers reuse detection."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@12345\",\n  \"newPassword\": \"Admin@67890\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] },
            "description": "Revokes all sessions on success — you must log in again afterwards."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"allDevices\": false\n}" },
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
