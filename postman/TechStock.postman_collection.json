          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Entered in error\"\n}" },
            "url": { "raw": "{{baseUrl}}/sales/{{saleId}}/cancel", "host": ["{{baseUrl}}"], "path": ["sales", "{{saleId}}", "cancel"] },
