          "name": "Create sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('saleId', d.id);",
                  "if (d.items && d.items.length) pm.collectionVariables.set('saleItemId', d.items[0].id);",
