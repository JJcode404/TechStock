            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerId\": null,\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"priceTier\": \"RETAIL\",\n      \"discount\": 0\n    }\n  ],\n  \"payments\": [\n    { \"method\": \"CASH\", \"amount\": 600000 }\n  ],\n  \"generateInvoice\": false,\n  \"notes\": \"Walk-in customer\"\n}" },
            "url": { "raw": "{{baseUrl}}/sales", "host": ["{{baseUrl}}"], "path": ["sales"] },
            "description": "Deducts stock atomically. priceTier: RETAIL | WHOLESALE | DEALER (or pass explicit `unitPrice`). Credit/partial payments require a `customerId`."
          }
